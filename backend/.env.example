# LLM 配置 (支持任何 OpenAI 兼容 API: DeepSeek, Ollama, OpenAI 等)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat

# 如果使用 Ollama 本地模型:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5

# 如果使用 OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# 服务器配置
HOST=0.0.0.0
PORT=8000

# RAG 配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
